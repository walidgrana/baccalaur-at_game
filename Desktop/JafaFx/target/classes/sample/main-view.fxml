<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.Cursor?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" 
            style="-fx-background-color: linear-gradient(to bottom right, #4a90d9, #8b5cf6, #7c3aed);" 
            xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="sample.MainController">
    
    <!-- Main Content -->
    <VBox alignment="CENTER" layoutX="0.0" layoutY="80.0" prefWidth="600.0" spacing="30.0" 
          AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        
        <!-- Title -->
        <Label style="-fx-text-fill: white; -fx-font-style: italic;" text="Baccalauréat +">
            <font>
                <Font name="System Italic" size="48.0" />
            </font>
        </Label>
        
        <!-- Logo Circle -->
        <Label style="-fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 50; -fx-padding: 15 20 15 20; -fx-border-width: 2;" text="CI">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
        
        <!-- Play Button -->
        <Button fx:id="playButton" onAction="#onPlayButtonClick" 
                prefHeight="50.0" prefWidth="250.0" 
                style="-fx-background-color: #22c55e; -fx-background-radius: 25; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" 
                text="PLAY">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
            <cursor>
                <Cursor fx:constant="HAND" />
            </cursor>
        </Button>
        
    </VBox>
    
    <!-- Settings Button -->
    <Button fx:id="settingsButton" onAction="#onSettingsClick" 
            layoutX="20.0" layoutY="350.0" 
            mnemonicParsing="false" 
            style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 24;" 
            text="⚙">
        <cursor>
            <Cursor fx:constant="HAND" />
        </cursor>
    </Button>
    
</AnchorPane>
